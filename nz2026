            if (pathCoords.length === 1) {
                const pt = pathCoords[0];
                L.marker(pt, {icon: L.divIcon({ className:'', html: `<div class="daily-node-marker" style="width:24px;height:24px;">📍</div>`, iconSize:[24,24], iconAnchor:[12,12] })}).addTo(dailyLayerGroup);
                dailyMap.setView(pt, 11);
                return;
            }

            const drawMarkers = () => {
                const uniqueStrs = new Set();
                pathCoords.forEach((pt, i) => {
                    const str = `${pt[0]},${pt[1]}`;
                    if(!uniqueStrs.has(str)) {
                        uniqueStrs.add(str);
                        const name = locNames[str] || "";
                        const isEnd = (i === pathCoords.length -1) || (i === 0);
                        const nodeHTML = L.divIcon({ className: '', html: `<div class="daily-node-marker" style="width:14px; height:14px; background-color:${isEnd?'#ef4444':'#10b981'}; border:2px solid white;"></div>`, iconSize: [14,14], iconAnchor: [7,7] });
                        L.marker(pt, {icon: nodeHTML}).bindTooltip(name, {permanent: true, direction: 'right', className: 'text-xs font-bold bg-white/90 border-0 shadow-sm px-1 py-0.5 ml-1'}).addTo(dailyLayerGroup);
                    }
                });
            };

            const fallbackLine = L.polyline(pathCoords, { color: '#94a3b8', weight: 3, dashArray: '5,5' }).addTo(dailyLayerGroup);
            dailyMap.fitBounds(fallbackLine.getBounds(), { padding: [40, 40] });
            drawMarkers();

            // Open Source Routing Machine (OSRM) integration for realistic roads
            if (routeCache[index]) {
                dailyLayerGroup.removeLayer(fallbackLine);
                L.geoJSON(routeCache[index], { style: { color: '#3b82f6', weight: 5, opacity: 0.8 } }).addTo(dailyLayerGroup);
                drawMarkers(); 
            } else {
                const coordsString = pathCoords.map(c => `${c[1]},${c[0]}`).join(';');
                const osrmUrl = `https://router.project-osrm.org/route/v1/driving/${coordsString}?overview=full&geometries=geojson`;
                fetch(osrmUrl).then(res => res.json()).then(data => {
                    if (data.code === 'Ok' && data.routes.length > 0) {
                        routeCache[index] = data.routes[0].geometry; 
                        dailyLayerGroup.removeLayer(fallbackLine); 
                        L.geoJSON(routeCache[index], { style: { color: '#3b82f6', weight: 5, opacity: 0.8 } }).addTo(dailyLayerGroup);
                        drawMarkers(); 
                    }
                }).catch(err => console.warn("OSRM routing fallback", err));
            }
        }

        // --- Chart Initialization ---
        function initChart() {
            // Day 7: Walter Peak (140), Day 8: Cardrona (70)
            const drivingData = [15, 190, 230, 210, 200, 70, 140, 70, 160, 10, 430, 160, 20, 15, 15];
            const ctx = document.getElementById('drivingChart').getContext('2d');
            myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: itineraryData.map(d => d.day),
                    datasets: [{
                        label: '單日里程 (km)',
                        data: drivingData,
                        backgroundColor: drivingData.map(d => d > 200 ? 'rgba(30, 58, 138, 0.8)' : 'rgba(147, 197, 253, 0.8)'),
                        borderRadius: 4
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        }

        // Initialize
        window.onload = () => { buildUI(); initChart(); switchTab('map'); };
    </script>
</body>
</html>
